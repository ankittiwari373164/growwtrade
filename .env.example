# Token can also be pasted in the dashboard each morning instead of here.
GROWW_ACCESS_TOKEN=
# Strong secret: required to POST the token and to run /api/log-outcomes
DASHBOARD_SECRET=change-me
# "true" scrapes the live movers page; "false" uses the hardcoded fallback
ENABLE_SCRAPE=true
# Universe source: top-volume (most active) | top-gainers | top-losers
UNIVERSE_SOURCE=top-volume
# How many stocks to analyze
TOP_N=8
# Analysis cache seconds
CACHE_TTL=120
# Where the SQLite signal log lives (persists only on a disk-backed host)
DATA_DIR=./data
